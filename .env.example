# EvalKit environment variables (placeholders only — copy to .env.local)
# Canonical reference: docs/ENV.md

# Vercel AI Gateway — all model calls (Slice 01+)
AI_GATEWAY_API_KEY=

# Vercel KV / Upstash (Slice 02+)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel Sandbox OIDC — auto in Vercel prod; run `vercel env pull` locally (Slice 05+)
VERCEL_OIDC_TOKEN=

# Slack / Chat SDK (Slice 12+)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
