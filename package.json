{
  "name": "evalkit",
  "version": "1.0.0",
  "private": true,
  "description": "AI eval harness for deployed chatbots",
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "undici": "7.28.0",
    "@swc/helpers": "0.5.23",
    "chokidar": "5.0.0",
    "readdirp": "5.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts",
    "test:contract": "node scripts/test-na.mjs contract vitest.config.contract.ts",
    "test:crud": "node scripts/test-na.mjs crud vitest.config.crud.ts",
    "test:integration": "node scripts/test-na.mjs integration vitest.config.integration.ts",
    "test:eval": "tsx evals/run-evals.ts",
    "gates": "npm run typecheck && npm run lint && npm run test && npm run test:contract && npm run test:crud && npm run test:integration && npm run test:eval && npm run build",
    "audit:ci": "npm audit --audit-level=high",
    "prepare": "node -e \"try{require('husky')}catch(e){}\" || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix --max-warnings=0"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.133",
    "@base-ui/react": "^1.6.0",
    "@opentelemetry/api": "^1.9.1",
    "@vercel/kv": "^3.0.0",
    "@vercel/sandbox": "^2.2.1",
    "ai": "^6.0.208",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "^15.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "workflow": "^4.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@workflow/vitest": "^4.0.11",
    "eslint": "^9",
    "eslint-config-next": "^15.3.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
